{
  "info": {
    "name": "reservation_api",
    "description": "API collection for reservation system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Juan Admin\",\n  \"email\": \"juan.admin@example.com\",\n  \"phone\": \"5511111111\",\n  \"roleId\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/users/",
              "host": ["{{base_url}}"],
              "path": ["users"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
